    hum = newChar:WaitForChild("Humanoid")
end)

local SPEED = 16
local MAX_GLIDE = 10

local glideVel = Vector3.zero

UIS.InputBegan:Connect(function(input)
    if not GlideEnabled then return end

    if input.KeyCode == Enum.KeyCode.W 
    or input.KeyCode == Enum.KeyCode.A
    or input.KeyCode == Enum.KeyCode.S
    or input.KeyCode == Enum.KeyCode.D then
        glideVel = Vector3.zero
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if not GlideEnabled then return end
    if not hum or hum.Health <= 0 then return end

    hum.WalkSpeed = SPEED

    local moveDir = hum.MoveDirection

    if moveDir.Magnitude > 0 then
        hrp.Velocity = moveDir * SPEED
    else
        glideVel = glideVel * (1 - GlideForceValue)
        glideVel = glideVel + Vector3.new(0, -workspace.Gravity * dt, 0)

        if glideVel.Magnitude > MAX_GLIDE then
            glideVel = glideVel.Unit * MAX_GLIDE
        end

        hrp.Velocity = glideVel
    end
end)
